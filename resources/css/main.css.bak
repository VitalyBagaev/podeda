* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary: #e30613;
    --secondary: #666;
    --light: #f8f8f8;
    --border: #e0e0e0;
    --accent: #e30613;
    --text-main: #1a1a1a;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--text-main);
    background: #fff;
    line-height: 1.6;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* Header */
header {
    background: #fff;
    border-bottom: 1px solid var(--border);
    padding: 15px 0;
    position: sticky;
    top: 0;
    z-index: 100;
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-size: 24px;
    font-weight: 700;
    text-decoration: none;
    color: var(--primary);
}

nav ul {
    display: flex;
    list-style: none;
    gap: 30px;
}

nav a {
    text-decoration: none;
    color: var(--secondary);
    font-weight: 500;
    transition: color 0.2s;
}

nav a:hover {
    color: var(--accent);
}

.btn {
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
}

.btn-primary {
    background: var(--primary);
    color: #fff;
}

.btn-primary:hover {
    background: #c00510;
}

.btn-secondary {
    background: #eee;
    color: #333;
}

.btn-secondary:hover {
    background: #e0e0e0;
}

.btn-small {
    padding: 5px 10px;
    font-size: 12px;
}

/* Main */
main {
    padding: 40px 0;
    min-height: calc(100vh - 200px);
}

.page-title {
    font-size: 32px;
    margin-bottom: 30px;
    text-align: center;
}

/* Categories */
.categories-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
}

.btn-category {
    background: #fff;
    border: 1px solid var(--border);
    color: var(--text-main);
}

.btn-category.active {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
}

/* Pagination */
.pagination {
    display: flex;
    gap: 5px;
    justify-content: center;
    margin: 20px 0;
}

.pagination button {
    padding: 8px 12px;
    border: 1px solid var(--border);
    background: #fff;
    cursor: pointer;
    border-radius: 4px;
}

.pagination .active {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
}

/* Comments */
.comment {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px;
    margin-bottom: 20px;
}

.comment-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
}

.comment-author {
    font-weight: 700;
}

.comment-date {
    font-size: 12px;
    color: var(--secondary);
}

.comment-text {
    margin-bottom: 15px;
}

.comment-photos {
    display: flex;
    gap: 10px;
    margin-bottom: 15px;
}

.comment-photo {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
}

.comment-footer {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 15px;
    border-top: 1px solid #eee;
}

.likes-display {
    font-weight: 600;
    color: var(--secondary);
}

.like-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
}

/* Profile */
.profile-header {
    display: flex;
    gap: 30px;
    background: #fff;
    padding: 30px;
    border: 1px solid var(--border);
    border-radius: 4px;
    margin-bottom: 30px;
}

.profile-avatar-section {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.profile-avatar {
    width: 150px;
    height: 150px;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
}

.profile-info {
    flex: 1;
}

.profile-field {
    margin-bottom: 15px;
}

.profile-field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--secondary);
    margin-bottom: 5px;
}

.profile-field input, .profile-field select {
    width: 100%;
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
}

.service-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    background: var(--light);
    border-radius: 4px;
    margin-bottom: 10px;
}

.service-category {
    font-weight: 600;
}

.service-date {
    font-size: 13px;
    color: var(--secondary);
}

/* Admin */
.admin-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

.admin-tab {
    padding: 10px 20px;
    background: #eee;
    border: none;
    cursor: pointer;
    border-radius: 4px;
}

.admin-tab.active {
    background: var(--primary);
    color: #fff;
}

.users-table {
    width: 100%;
    border-collapse: collapse;
}

.users-table th, .users-table td {
    padding: 12px;
    border-bottom: 1px solid var(--border);
    text-align: left;
}

.mt-8 { margin-top: 40px; }
.mt-2 { margin-top: 10px; }
.mb-2 { margin-bottom: 10px; }
.p-4 { padding: 20px; }
.card { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 20px; }
